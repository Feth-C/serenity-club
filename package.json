{
    "name": "serenity-club",
    "version": "1.0.5",
    "description": "Serenity Club Desktop Application",
    "author": "Feth-C",
    "main": "electron/main.cjs",
    "scripts": {
        "start": "electron ./electron/main.cjs",
        "build:frontend": "cd frontend && npm run build",
        "dist": "npm run build:frontend && electron-builder"
    },
    "build": {
        "appId": "com.serenity.club",
        "productName": "Serenity Club",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "electron/**/*",
            "backend/**/*",
            "frontend/dist/**/*",
            "package.json"
        ],
        "win": {
            "target": "nsis",
            "icon": "frontend/public/Serenity_Fivecon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "publish": {
            "provider": "github",
            "releaseType": "release"
        }
    },
    "devDependencies": {
        "electron-builder": "^24.0.0"
    },
    "dependencies": {
        "electron-updater": "^6.8.3"
    }
}